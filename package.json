{
  "name": "allocato",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Salary planner: allocate a salary across buckets; whatever is left over is the spendable daily allowance.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo": "vitest run demo/demo.spec.ts --disable-console-intercept",
    "deploy": "npm run build && wrangler pages deploy dist --project-name allocatto"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  }
}
