# Node dependencies — regenerable via `npm install`, never committed
node_modules/

# Build output & test coverage
dist/
dev-dist/
coverage/
*.tsbuildinfo

# Logs & OS cruft
*.log
.DS_Store

# Local AI work context (work logs, handovers) — not committed
.context/

# Scratch / out-of-context throwaway files — never committed
.scratch/

# Local demo / manual run scripts — kept local, not committed
demo/

# Cursor: local-only — kept on disk (rules still apply) but never committed
.cursor/